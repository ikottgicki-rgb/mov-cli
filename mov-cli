class HLSProxy(BaseHTTPRequestHandler):
    def log_message(self, *args):
        pass  # suppress access logs

    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)
        params = urllib.parse.parse_qs(parsed.query)

        if parsed.path == "/master":
            self._serve_master(params.get("url", [""])[0])
        elif parsed.path == "/playlist":
            self._serve_playlist(params.get("url", [""])[0])
        elif parsed.path == "/seg":
            self._serve_segment(params.get("url", [""])[0])
        else:
            self.send_response(404)
            self.end_headers()

    def _proxy_url(self, kind, url):
        return f"http://127.0.0.1:{self.server.proxy_port}/{kind}?url={urllib.parse.quote(url, safe='')}"

    def _serve_master(self, orig_url):
        raw = fetch(orig_url, TIK_HEADERS)
        if not raw:
            self.send_response(502)
            self.end_headers()
            return
        text = raw.decode()
        # Rewrite playlist URLs to go through proxy
        def rewrite(m):
            return self._proxy_url("playlist", m.group(0))
        text = re.sub(r"https://tik\.aether\.mom/\S+/playlist\.m3u8", rewrite, text)
        body = text.encode()
        self.send_response(200)
        self.send_header("Content-Type", "application/vnd.apple.mpegurl")
        self.send_header("Content-Length", len(body))
        self.end_headers()
        self.wfile.write(body)

    def _serve_playlist(self, orig_url):
        raw = fetch(orig_url, TIK_HEADERS)
        if not raw:
            self.send_response(502)
            self.end_headers()
            return
        text = raw.decode()
        seg_urls = re.findall(r"https://p\d+-[a-z]+\.tiktokcdn\.com/\S+", text)
        # Prefetch first 8 segments in background
        def prefetch(urls):
            for u in urls[:8]:
                with SEG_CACHE_LOCK:
                    if u in SEG_CACHE:
                        continue
                png = fetch(u, SEG_HEADERS)
                if png:
                    with SEG_CACHE_LOCK:
                        SEG_CACHE[u] = extract_ts_from_png(png)
        threading.Thread(target=prefetch, args=(seg_urls,), daemon=True).start()
        # Rewrite TikTok CDN segment URLs to go through proxy
        def rewrite(m):
            return self._proxy_url("seg", m.group(0))
        text = re.sub(r"https://p\d+-[a-z]+\.tiktokcdn\.com/\S+", rewrite, text)
        body = text.encode()
        self.send_response(200)
        self.send_header("Content-Type", "application/vnd.apple.mpegurl")
        self.send_header("Content-Length", len(body))
        self.end_headers()
        self.wfile.write(body)

    def _serve_segment(self, orig_url):
        with SEG_CACHE_LOCK:
            ts_data = SEG_CACHE.get(orig_url)
        if ts_data is None:
            png_data = fetch(orig_url, SEG_HEADERS)
            if not png_data:
                self.send_response(502)
                self.end_headers()
                return
            ts_data = extract_ts_from_png(png_data)
            with SEG_CACHE_LOCK:
                SEG_CACHE[orig_url] = ts_data
                if len(SEG_CACHE) > 30:
                    oldest = next(iter(SEG_CACHE))
                    del SEG_CACHE[oldest]
        self.send_response(200)
        self.send_header("Content-Type", "video/mp2t")
        self.send_header("Content-Length", len(ts_data))
        self.end_headers()
        self.wfile.write(ts_data)


def start_proxy():
    port = free_port()
    server = ThreadingHTTPServer(("127.0.0.1", port), HLSProxy)
    server.proxy_port = port
    t = threading.Thread(target=server.serve_forever, daemon=True)
    t.start()
    return server, port


def tmdb_search(query):
    q = urllib.parse.quote(query)
    results_box = {}

    def fetch_movies():
        results_box["movies"] = fetch_json(
            f"https://api.themoviedb.org/3/search/movie?query={q}&language=en-US&page=1",
            TMDB_HEADERS,
        ).get("results", [])

    def fetch_shows():
        results_box["shows"] = fetch_json(
            f"https://api.themoviedb.org/3/search/tv?query={q}&language=en-US&page=1",
            TMDB_HEADERS,
        ).get("results", [])

    t1 = threading.Thread(target=fetch_movies)
    t2 = threading.Thread(target=fetch_shows)
    t1.start(); t2.start()
    t1.join(); t2.join()
    movies = results_box.get("movies", [])
    shows = results_box.get("shows", [])

    results = []
    for m in movies[:12]:
        year = m.get("release_date", "")[:4] or "?"
        results.append({
            "type": "movie",
            "id": m["id"],
            "display": f"[Movie] {m['title']} ({year})",
        })
    for s in shows[:8]:
        year = s.get("first_air_date", "")[:4] or "?"
        results.append({
            "type": "tv",
            "id": s["id"],
            "display": f"[TV]    {s['name']} ({year})",
        })
    return results


def fzf(options, prompt):
    proc = subprocess.run(
        ["fzf", "--prompt", prompt, "--height=~40%", "--layout=reverse", "--border"],
        input="\n".join(options),
        capture_output=True,
        text=True,
    )
    return proc.stdout.strip() if proc.returncode == 0 else None


def get_stream(media_type, tmdb_id, season=None, episode=None, slug=""):
    # Primary: tik.aether.mom direct API
    if media_type == "movie":
        url = f"https://tik.aether.mom/movie/{tmdb_id}"
    else:
        url = f"https://tik.aether.mom/tv/{tmdb_id}/{season}/{episode}"
    data = fetch_json(url, TIK_HEADERS)
    stream = data.get("stream")
    if stream:
        return stream

    # Fallback: Playwright — lets all aether.mom browser scrapers run
    print("Primary source unavailable, trying fallback sources (this may take ~15s)...")
    return get_stream_playwright(media_type, tmdb_id, season, episode, slug)


def get_stream_playwright(media_type, tmdb_id, season, episode, slug=""):
    import asyncio
    try:
        from playwright.async_api import async_playwright
    except ImportError:
        return None

    async def run():
        async with async_playwright() as p:
            browser = await p.chromium.launch(headless=False, args=["--window-size=800,500"])
            context = await browser.new_context(
                user_agent="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
            )
            page = await context.new_page()
            found = {}

            async def on_response(resp):
                if found.get("stream"):
                    return
                url = resp.url
                if "master.m3u8" in url:
                    found["stream"] = url
                    return
                ct = resp.headers.get("content-type", "")
                if "json" in ct:
                    try:
                        import json as _json
                        body = await resp.text()
                        d = _json.loads(body)
                        # {"stream": "..."} format (tik.aether.mom)
                        if d.get("stream"):
                            found["stream"] = d["stream"]
                            return
                        # xpass.top playlist format
                        for item in d.get("playlist", []):
                            for src in item.get("sources", []):
                                f = src.get("file", "")
                                if f and f.startswith("http") and "error" not in f:
                                    found["stream"] = f
                                    return
                    except Exception:
                        pass

            page.on("response", on_response)

            if media_type == "movie":
                page_url = f"https://aether.mom/media/tmdb-movie-{tmdb_id}-{slug}"
            else:
                page_url = f"https://aether.mom/media/tmdb-tv-{tmdb_id}-{slug}?episode.t={tmdb_id}&season.n={season}&episode.n={episode}"

            await page.goto(page_url, wait_until="domcontentloaded", timeout=20000)

            # Wait up to 20s for a stream to appear
            for _ in range(20):
                if found.get("stream"):
                    break
                await asyncio.sleep(1)

            await browser.close()
            return found.get("stream")

    return asyncio.run(run())


