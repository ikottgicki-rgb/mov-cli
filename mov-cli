def fetch_subtitles(imdb_id, season=None, episode=None):
    # Strip "tt" prefix if present, pad to 7 digits
    num = imdb_id.lstrip("t") if imdb_id else ""
    url = f"https://rest.opensubtitles.org/search/imdbid-{num}/sublanguageid-eng"
    if season:
        url += f"/season-{season}/episode-{episode}"
    data = fetch_json(url, OSUB_HEADERS)
    if not isinstance(data, list):
        return []
    subs = [s for s in data if s.get("SubFormat", "").lower() == "srt"]
    subs.sort(key=lambda s: int(s.get("SubDownloadsCnt", 0)), reverse=True)
    return subs


def pick_and_download_sub(subs):
    if not subs:
        print("No subtitles found.")
        return None
    displays = [f"{s['SubFileName']}  ({s.get('SubDownloadsCnt','?')} dl)" for s in subs[:20]]
    displays.insert(0, "-- No subtitles --")
    sel = fzf(displays, "Subtitles: ")
    if not sel or sel == "-- No subtitles --":
        return None
    idx = displays.index(sel) - 1
    sub_url = subs[idx].get("SubDownloadLink")
    if not sub_url:
        return None
    data = fetch(sub_url, OSUB_HEADERS)
    if not data:
        return None
    # OpenSubtitles returns gzipped srt
    import gzip
    try:
        data = gzip.decompress(data)
    except Exception:
        pass
    with open(SUB_PATH, "wb") as f:
        f.write(data)
    return SUB_PATH


def pipe_to_mpv(master_url, title, sub_file=None):
    # Fetch master playlist - try with tik headers first, fall back to plain
    for hdrs in [TIK_HEADERS, SEG_HEADERS]:
        raw = fetch(master_url, hdrs)
        if raw:
            break
    if not raw:
        print("Could not fetch stream.")
        return
    master = raw.decode()

    # Find quality playlist URL
    playlist_match = re.search(r"https://\S+/playlist\.m3u8", master)
    if not playlist_match:
        # master IS the playlist (no quality variants)
        playlist_url = master_url
        playlist = master
    else:
        playlist_url = playlist_match.group(0)
        hdrs2 = TIK_HEADERS if "tik.aether.mom" in playlist_url else SEG_HEADERS
        playlist = fetch(playlist_url, hdrs2).decode()

    # Extract all segment URLs from playlist
    all_segs = re.findall(r"https?://\S+", playlist)
    all_segs = [s for s in all_segs if not s.endswith(".m3u8")]

    if not all_segs:
        print("No segments found.")
        return

    # Check if segments are PNG-wrapped (peek at first segment's magic bytes)
    first_seg = fetch(all_segs[0], SEG_HEADERS, timeout=8)
    is_png = first_seg[:4] == b"\x89PNG"

    if not is_png:
        # Standard HLS — pass directly to mpv with Origin header
        print(f"\nPlaying: {title}")
        cmd = [
            "mpv", master_url,
            "--cache=yes", "--demuxer-max-bytes=50MiB",
            "--http-header-fields=Origin: https://aether.mom",
            f"--referrer=https://aether.mom/",
            f"--title={title}",
        ]
        if sub_file:
            cmd += [f"--sub-file={sub_file}"]
        subprocess.run(cmd)
        return

    seg_urls = all_segs
    print(f"\nPlaying: {title}  ({len(seg_urls)} segments, ~{len(seg_urls)*2//60}min)")

    # Create FIFO so mpv's stdin stays attached to the terminal (keyboard works)
    if os.path.exists(FIFO_PATH):
        os.remove(FIFO_PATH)
    os.mkfifo(FIFO_PATH)

    import queue as _queue
    q = _queue.Queue(maxsize=8)

    def fetcher():
        for url in seg_urls:
            png = fetch(url, SEG_HEADERS)
            q.put(extract_ts_from_png(png) if png else b"")
        q.put(None)

    threading.Thread(target=fetcher, daemon=True).start()

    def writer():
        try:
            with open(FIFO_PATH, "wb") as f:
                while True:
                    ts = q.get()
                    if ts is None:
                        break
                    f.write(ts)
                    f.flush()
        except BrokenPipeError:
            pass
        finally:
            try:
                os.remove(FIFO_PATH)
            except Exception:
                pass

    threading.Thread(target=writer, daemon=True).start()

    cmd = ["mpv", FIFO_PATH, "--cache=yes", "--demuxer-max-bytes=50MiB", f"--title={title}"]
    if sub_file:
        cmd += [f"--sub-file={sub_file}"]
    subprocess.run(cmd)


def play(stream_url, title, sub_file=None):
    pipe_to_mpv(stream_url, title, sub_file)


