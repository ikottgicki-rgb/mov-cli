def fetch(url, headers, timeout=8):
    try:
        r = _session.get(url, headers=headers, timeout=(5, timeout))
        if not r.ok:
            print(f"HTTP {r.status_code}: {url}", file=sys.stderr)
            return b""
        return r.content
    except Exception as e:
        print(f"Fetch error: {e}", file=sys.stderr)
        return b""


def fetch_json(url, headers):
    data = fetch(url, headers)
    try:
        return json.loads(data) if data else {}
    except Exception:
        return {}


def extract_ts_from_png(data):
    """Extract MPEG-TS payload hidden after IEND chunk in a PNG."""
    iend = data.find(b"IEND")
    if iend < 0:
        return data
    return data[iend + 8:]


